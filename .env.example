# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/last_mile_delivery

# Clerk Authentication Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# App URL (localhost for dev; set to Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP Configuration for Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abc@gmail.com
SMTP_PASS=1234567890

SMTP_FROM=abc@gmail.com

# Mapbox Token (Optional, falls back to OpenStreetMap if empty)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# Twilio SMS Configuration (Optional, falls back to console logs if empty)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

